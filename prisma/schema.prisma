generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  creditCards  CreditCard[]
  bills        Bill[]
  deductions   TaxDeduction[]
  lendings     Lending[]
  categories   Category[]
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "income" | "expense"
  category     String
  channel      String   // "cash" | "transfer" | "credit"
  amount       Float
  note         String   @default("")
  date         DateTime
  creditCardId String?
  groupId      String?  // links related transactions (e.g. salary + tax + social security)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
}

model CreditCard {
  id           String        @id @default(cuid())
  userId       String
  bankName     String
  cardNumber   String
  creditLimit  Float
  balance      Float         @default(0)
  dueDate      Int
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Float
  dueDay    Int
  isPaid    Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaxDeduction {
  id        String   @id @default(cuid())
  userId    String
  category  String
  name      String
  amount    Float
  maxLimit  Float
  taxYear   Int      @default(2568)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lending {
  id          String    @id @default(cuid())
  userId      String
  borrower    String    // ชื่อคนยืม
  amount      Float     // จำนวนเงินที่ให้ยืม
  description String    @default("")
  date        DateTime
  isReturned  Boolean   @default(false)
  returnedAt  DateTime?
  returnedAmount Float  @default(0)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "income" | "expense"
  value     String   // unique key per user+type
  label     String   // display name
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  creditCards  CreditCard[]
  bills        Bill[]
  deductions   TaxDeduction[]
  lendings     Lending[]
  categories   Category[]
  savingsAccounts SavingsAccount[]
  investments  Investment[]
  investmentAccounts InvestmentAccount[]
  physicalAssets PhysicalAsset[]
  exchangeRates ExchangeRate[]
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "income" | "expense"
  category     String
  channel      String   // "cash" | "transfer" | "credit"
  amount       Float
  note         String   @default("")
  date         DateTime
  creditCardId String?
  groupId      String?  // links related transactions (e.g. salary + tax + social security)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
}

model CreditCard {
  id           String        @id @default(cuid())
  userId       String
  bankName     String
  cardNumber   String
  creditLimit  Float
  balance      Float         @default(0)
  dueDate      Int
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Float
  dueDay    Int
  isPaid    Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaxDeduction {
  id        String   @id @default(cuid())
  userId    String
  category  String
  name      String
  amount    Float
  maxLimit  Float
  taxYear   Int      @default(2568)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lending {
  id          String    @id @default(cuid())
  userId      String
  borrower    String    // ชื่อคนยืม
  amount      Float     // จำนวนเงินที่ให้ยืม
  description String    @default("")
  date        DateTime
  isReturned  Boolean   @default(false)
  returnedAt  DateTime?
  returnedAmount Float  @default(0)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "income" | "expense"
  value     String   // unique key per user+type
  label     String   // display name
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
}

model SavingsAccount {
  id           String              @id @default(cuid())
  userId       String
  name         String              // ชื่อบัญชี เช่น "ออมฉุกเฉิน", "เที่ยว"
  bankName     String              // ธนาคาร
  accountNumber String  @default("") // เลขบัญชี (optional)
  balance      Float               @default(0)
  goal         Float?              // เป้าหมาย (optional)
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions SavingsTransaction[]
}

model SavingsTransaction {
  id               String         @id @default(cuid())
  savingsAccountId String
  type             String         // "deposit" | "withdraw"
  amount           Float
  note             String         @default("")
  date             DateTime
  createdAt        DateTime       @default(now())
  savingsAccount   SavingsAccount @relation(fields: [savingsAccountId], references: [id], onDelete: Cascade)
}

model Investment {
  id            String                @id @default(cuid())
  userId        String
  name          String
  type          String                // "gold" | "stock" | "fund" | "crypto" | "bond" | "other"
  currency      String                @default("THB")
  costBasis     Float                 @default(0) // ต้นทุนรวม (ในสกุลเงินต้นทาง)
  currentValue  Float                 @default(0) // มูลค่าปัจจุบัน (ในสกุลเงินต้นทาง)
  units         Float                 @default(0)
  note          String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  InvestmentTransaction[]
}

model InvestmentTransaction {
  id            String     @id @default(cuid())
  investmentId  String
  type          String     // "buy" | "sell" | "value_update"
  amount        Float
  units         Float      @default(0)
  pricePerUnit  Float      @default(0)
  exchangeRate  Float      @default(1) // rate at time of transaction
  note          String     @default("")
  date          DateTime
  createdAt     DateTime   @default(now())
  investment    Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
}

model PhysicalAsset {
  id            String   @id @default(cuid())
  userId        String
  name          String   // เช่น "ทองก้อน 5 บาท", "คอนโด", "รถยนต์"
  type          String   // "gold" | "property" | "vehicle" | "collectible" | "other"
  purchaseValue Float    @default(0)
  currentValue  Float    @default(0)
  purchaseDate  DateTime?
  note          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvestmentAccount {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // "THB" | "USD" | "EUR" etc.
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // "USD" | "EUR" | "JPY" etc.
  rate      Float    // 1 unit of currency = X THB
  updatedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}
